# =============================================================================
# Seredeli Room 环境变量配置示例
# =============================================================================
# 复制此文件为 .env 并修改配置值
# 配置优先级（从高到低）：
# 1. 环境变量（本文件）
# 2. 数据库配置（system_configs 表）
# 3. 配置文件（config.toml）
# 4. 代码默认值
# =============================================================================

# -----------------------------------------------------------------------------
# 应用配置
# -----------------------------------------------------------------------------
# 运行环境：development, test, production
APP_ENV=development

# -----------------------------------------------------------------------------
# 服务器配置
# -----------------------------------------------------------------------------
SERVER_HOST=0.0.0.0
SERVER_PORT=3000

# -----------------------------------------------------------------------------
# 数据库配置（必须配置）
# -----------------------------------------------------------------------------
DATABASE_URL=postgres://username:password@localhost:5432/seredeli_room
DATABASE_MAX_CONNECTIONS=10

# -----------------------------------------------------------------------------
# JWT 配置（必须配置）
# -----------------------------------------------------------------------------
# JWT 密钥（生产环境必须使用强密钥）
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRATION_HOURS=24

# -----------------------------------------------------------------------------
# 文件上传配置
# -----------------------------------------------------------------------------
# 上传文件存储的物理路径（必需）
UPLOAD_DIR=./uploads
# 最大文件大小（字节），默认 10MB
UPLOAD_MAX_FILE_SIZE=10485760
# 文件访问的基础URL路径，默认 "/uploads"
UPLOAD_BASE_URL=/uploads

# -----------------------------------------------------------------------------
# 速率限制配置
# -----------------------------------------------------------------------------
# 是否启用速率限制
RATE_LIMIT_ENABLED=true

# -----------------------------------------------------------------------------
# 日志配置
# -----------------------------------------------------------------------------
# 日志级别：error, warn, info, debug, trace
RUST_LOG=info
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# 系统配置
# -----------------------------------------------------------------------------
# 是否开启维护模式
MAINTENANCE_MODE=false
