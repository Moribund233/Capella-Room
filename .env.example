# 应用环境配置
# 可选值: development, production, test
APP_ENV=development

# 服务器配置
# 使用双下划线表示嵌套: APP_SERVER__HOST = server.host
APP_SERVER__HOST=0.0.0.0
APP_SERVER__PORT=3000

# 数据库配置
DATABASE_URL=postgres://username:password@localhost:5432/seredeli_room
APP_DATABASE__MAX_CONNECTIONS=10

# JWT配置
JWT_SECRET=your-super-secret-jwt-key-change-in-production
APP_JWT__EXPIRATION_HOURS=24

# 日志级别
RUST_LOG=info
