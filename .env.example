# =============================================================================
# Capella Room Environment Variables Configuration
# =============================================================================
# [Usage Instructions]
# 1. Copy this file to .env: cp .env.example .env
# 2. Modify the values in .env according to your environment
# 3. Or set environment variables directly in your deployment platform (Docker/K8s/CI)
#
# Configuration Priority (from high to low):
# 1. System Environment Variables
# 2. .env file
# 3. config.toml configuration file
#
# [Security Notice] The following sensitive configurations must NOT be written to config.toml:
# - DATABASE_URL: Database connection string (contains password)
# - JWT_SECRET: JWT signing key
# - UPLOAD_DIR: File upload storage path
# - ADMIN_INITIAL_PASSWORD: Initial administrator password
# - REDIS_URL: Redis connection address
# =============================================================================

# -----------------------------------------------------------------------------
# Database Configuration (Required, Sensitive: contains password)
# -----------------------------------------------------------------------------
DATABASE_URL=postgres://username:password@localhost:5432/capella_room

# -----------------------------------------------------------------------------
# JWT Configuration (Required, Sensitive: signing key)
# -----------------------------------------------------------------------------
# JWT Secret (Production must use a strong key, recommended 256-bit random string)
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# -----------------------------------------------------------------------------
# File Upload Configuration (Required, Sensitive: physical path)
# -----------------------------------------------------------------------------
# Physical path for uploaded file storage (use absolute path in production)
UPLOAD_DIR=./uploads

# -----------------------------------------------------------------------------
# Administrator Configuration (Required, Sensitive: initial password)
# -----------------------------------------------------------------------------
# Initial administrator password (recommended to change after first login)
ADMIN_INITIAL_PASSWORD=admin123456

# -----------------------------------------------------------------------------
# Redis Configuration (Recommended for production / Required for multi-node)
# -----------------------------------------------------------------------------
# [IMPORTANT] Redis is used for the following core features:
#   1. Cross-node WebSocket message broadcast (multi-node deployment)
#   2. Configuration hot-reload synchronization across nodes
#   3. Audit log streaming (with fallback to direct DB write)
#
# Single-node deployment: Redis is optional, all features have fallback
# Multi-node deployment: Redis is REQUIRED for message broadcast and config sync
#
# [Note] Redis configuration is controlled entirely via environment variables,
# not read from config.toml. All configuration items have reasonable defaults.
# Only REDIS_URL needs to be set when Redis is enabled.
#
# Whether to enable Redis (default: false, recommended: true for production)
REDIS_ENABLED=false

# Redis connection address (required when enabled)
# Format: redis://[:password@]host[:port][/db]
# Example: redis://:mypassword@localhost:6379/0
REDIS_URL=redis://127.0.0.1:6379

# Optional configurations (can be omitted to use defaults):
# REDIS_POOL_SIZE=10              # Connection pool size
# REDIS_TIMEOUT_SECS=5            # Connection timeout (seconds)
# REDIS_CHANNEL_PREFIX=capella   # Pub/Sub channel prefix
# REDIS_STREAM_MAX_LEN=100000     # Stream max length
# REDIS_CONSUMER_BATCH_SIZE=100   # Consumer batch size
# REDIS_CONSUMER_POLL_INTERVAL_MS=1000  # Consumer poll interval (milliseconds)
# REDIS_CONFIG_SYNC_ENABLED=true  # Enable config sync (for multi-node deployment)

# -----------------------------------------------------------------------------
# Logging Configuration (Optional)
# -----------------------------------------------------------------------------
# Log level: error, warn, info, debug, trace (default: info)
RUST_LOG=info

# -----------------------------------------------------------------------------
# Server Configuration (Optional, overrides config.toml)
# -----------------------------------------------------------------------------
# Server host (default: 0.0.0.0)
# SERVER_HOST=0.0.0.0
# Server port (default: 3000)
# SERVER_PORT=3000
