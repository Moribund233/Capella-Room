# =============================================================================
# Seredeli Room Environment Variables Configuration Example
# =============================================================================
# [IMPORTANT] Usage Instructions:
# 1. Copy this file to .env (no suffix): cp .env.example .env
# 2. Set APP_ENV in .env file to specify runtime environment (development/test/production)
# 3. Application will automatically load corresponding .env.{APP_ENV} file based on APP_ENV
# 4. Sensitive configurations (database password, JWT secret, etc.) should be set in .env or .env.{environment} files
#
# Configuration Priority (from high to low):
# 1. System Environment Variables
# 2. .env.{APP_ENV} file (e.g., .env.development)
# 3. .env file
# 4. config.toml configuration file
#
# [Security Notice] The following sensitive configurations must NOT be written to config.toml:
# - DATABASE_URL: Database connection string (contains password)
# - JWT_SECRET: JWT signing key
# - UPLOAD_DIR: File upload storage path
# - ADMIN_INITIAL_PASSWORD: Initial administrator password
# - REDIS_URL: Redis connection address
# =============================================================================

# -----------------------------------------------------------------------------
# Runtime Environment Configuration (Required)
# Copy this line to your .env file and set to desired environment:
# APP_ENV=development  # Available values: development, test, production
# -----------------------------------------------------------------------------
# APP_ENV=development

# -----------------------------------------------------------------------------
# Database Configuration (Sensitive: contains password information)
# -----------------------------------------------------------------------------
DATABASE_URL=postgres://username:password@localhost:5432/seredeli_room

# -----------------------------------------------------------------------------
# JWT Configuration (Sensitive: signing key)
# -----------------------------------------------------------------------------
# JWT Secret (Production environment must use a strong key, recommended 256-bit random string)
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# -----------------------------------------------------------------------------
# File Upload Configuration (Sensitive: physical path information)
# -----------------------------------------------------------------------------
# Physical path for uploaded file storage (Required, use absolute path)
UPLOAD_DIR=./uploads

# -----------------------------------------------------------------------------
# Administrator Configuration (Sensitive: initial password)
# -----------------------------------------------------------------------------
# Initial administrator password (Recommended to change after first login)
ADMIN_INITIAL_PASSWORD=admin123456

# -----------------------------------------------------------------------------
# Redis Configuration (Sensitive: connection address may contain password)
# -----------------------------------------------------------------------------
# Whether to enable Redis, default false
REDIS_ENABLED=false
# Redis connection address (Required if Redis is enabled)
REDIS_URL=redis://127.0.0.1:6379
