# ============================================
# CapellaRoom 用户端 v2 环境配置示例
# ============================================

# 开发服务器端口（默认 5173）
VITE_PORT=5173

# 开发服务器主机（默认 0.0.0.0）
VITE_HOST=0.0.0.0

# 是否自动打开浏览器
VITE_OPEN_BROWSER=false

# API 基础 URL - 匹配 OpenResty /api/ 反向代理
VITE_API_BASE_URL=/api

# WebSocket URL - 匹配 OpenResty /ws 反向代理
VITE_WS_URL=wss://chat.moribund.top/ws

# GIPHY API Key（可选，有默认值）
# VITE_GIPHY_API_KEY=your_giphy_api_key
