# ============================================
# Seredeli Room User Client Environment Configuration
# ============================================
# Copy this file to .env and configure the values
# cp .env.example .env
# ============================================

# Development server port
VITE_PORT=5173

# Development server host
VITE_HOST=0.0.0.0

# Application environment
# - development: Use local configuration
# - production: Enable backend configuration
VITE_APP_ENV=production

# Backend API base URL (REQUIRED)
# Format: http://host:port
# Example for local OpenResty proxy: http://localhost:8765
VITE_BACKEND_URL=

# WebSocket base URL (REQUIRED)
# Format: ws://host:port or wss://host:port for secure connection
# Example for local: ws://localhost:8765
VITE_WS_URL=

# Whether to open browser on startup (optional)
# VITE_OPEN_BROWSER=true
