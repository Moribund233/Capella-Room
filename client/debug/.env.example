# Seredeli Room Debug Client Environment Variables Example
# 复制此文件为 .env 并修改配置

# 前端服务端口（默认 5173）
VITE_PORT=5173

# 后端 API 地址
# 开发环境使用本地 Nginx（根据 nginx.conf，Nginx 监听 8080 端口，代理到 Axum 3000 端口）
VITE_BACKEND_URL=http://localhost:8080

# 生产环境示例
# VITE_BACKEND_URL=https://api.seredeli.com

# WebSocket 地址
VITE_WS_URL=ws://localhost:8080/ws
